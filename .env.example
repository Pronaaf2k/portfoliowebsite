# Optional: raises GitHub's public API rate limit.
GITHUB_TOKEN=

# Steam live presence. STEAM_ID is the 17-digit SteamID64 value.
STEAM_API_KEY=
STEAM_ID=

# Spotify server integrations. Keep every value server-side.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Used only by the local one-time authorization helper. Register the live URL
# https://samiyeelalim.com/api/spotify/callback in Spotify as well, but keep
# this local value for the development-only connect flow.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback
# Optional for private or collaborative playlists and user-specific live status.
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_PLAYLIST_IDS=
MUSIC_EXCHANGE_SECRET=

# Aim Challenge and private music inbox. Never prefix these with NEXT_PUBLIC_.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
# Vercel/Upstash may provide these Redis-protocol URLs too. The app's fetch
# helper uses the REST values above; keep these for tools that speak Redis.
KV_URL=
REDIS_URL=
AIM_GAME_SECRET=

# Vercel Cron sends this value as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Search-engine ownership verification tokens, without surrounding HTML.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=