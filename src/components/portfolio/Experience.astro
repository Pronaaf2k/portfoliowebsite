---
import ExperienceItem from "./ExperienceItem.astro";
import Heading from "../ui/Heading.astro";
import { Icon } from "astro-icon/components";

const EXPERIENCE = [
  {
    date: "May 2026 – Present",
    title: "Full-Stack Developer (Contract)",
    company: "VoloLeads",
    link: "https://vololeads.com",
    description:
      "Built production billing for a live static site: Stripe Checkout for three subscription plans, Node/Express API, webhooks, PostgreSQL, SMTP confirmation emails, billing portal, and cPanel deployment. Frontend checkout integration on HTML/Tailwind plus ongoing iteration on contact forms, analytics, and renewal automation.",
  },
  {
    date: "December 2025",
    title: "Hackathon Finalist — Top 20 / 900",
    company: "Solvio AI Hackathon · Sheba.xyz & SheSTEM",
    description:
      "Ranked top 20 out of 900 teams in my first hackathon, demonstrating technical execution, innovation, and teamwork under pressure.",
  },
  {
    date: "Jan 2023 – Jun 2024",
    title: "Chief Marketing Officer",
    company: "Discount Den",
    description:
      "Led marketing strategy, branding, and growth initiatives for a consumer startup. Managed campaigns, positioning, and cross-functional project delivery.",
  },
  {
    date: "2022 – Present",
    title: "Private Tutor",
    company: "Cambridge O-Level & Pre O-Level",
    description:
      "One-on-one tutoring in mathematics and sciences for Cambridge O-Level and Pre O-Level students — lesson planning, progress tracking, and exam preparation.",
  },
  {
    date: "2022 – Present",
    title: "CSE Undergraduate",
    company: "North South University",
    description:
      "Bachelor of Science in Computer Science & Engineering. Focus on AI/ML, accessibility, and full-stack web development — building projects from research prototypes to production-shaped applications.",
  },
];
---

<section class="py-8 px-8 max-md:py-4 mb-4 scroll-m-16" id="experience">
  <div class="flex flex-col pt-8 max-w-4xl mx-auto">
    <div class="flex gap-4 items-center justify-center">
      <Icon class="text-3xl dark:text-white text-blacktext" name="briefcase" />
      <Heading text="My" textGradient="Journey" level={2} />
    </div>

    <div class="relative max-md:mt-0 mt-8" aria-label="Professional experience">
      <ol class="relative mt-10">
        {
          EXPERIENCE.map((experience, index) => (
            <li>
              <article
                role="article"
                aria-labelledby={`experience-title-${index}`}
              >
                <div
                  class="flex flex-col gap-2 text-blacktext dark:text-zinc-300 md:col-span-3"
                  aria-describedby={`experience-title-${index}`}
                >
                  <ExperienceItem {...experience} />
                </div>
              </article>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
