---
import Layout from "../../../layouts/Layout.astro";
import ListPosts from "../../../components/blog/ListPosts.astro";
import { getCollection } from "astro:content";

const [staticData] = await getCollection("staticData");
const { alias, pageDescription, OGImage } = staticData.data;

const pageTitle = `All Blog Posts | ${alias}`;
const description = `Browse all blog posts and articles by ${alias}`;
const ogimage = {
  url: OGImage.url,
  alt: `${alias}'s blog posts, highlighting AI/ML and web development skills.`,
};
---

<Layout pageTitle={pageTitle} description={description} ogimage={ogimage}>
  <div class="px-8 max-sm:px-4 py-8">
    <ListPosts all={true} />
  </div>
</Layout>

